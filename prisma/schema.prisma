generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/cidade.db"
}

model Cidade {
  idcidade Int       @id @default(autoincrement())
  nome     String
  estado   String
  clientes Cliente[]
}

model Cliente {
  idCliente       Int      @id @default(autoincrement())
  nome            String
  cpf             String
  endereco        String
  numero          Int
  complemento     String?
  bairro          String
  cidade_idcidade Int
  dtnasc          String?
  salario         Float?
  ativo           Int      @default(1)
  cidade          Cidade   @relation(fields: [cidade_idcidade], references: [idcidade])
  vendas          Venda[]
}

model Produto {
  idproduto     Int            @id @default(autoincrement())
  nome          String
  sku           String
  preco_venda   Float
  custo         Float
  ativo         Int            @default(1)
  produto_vendas ProdutoVenda[]
}

model Venda {
  idvenda           Int            @id @default(autoincrement())
  data_venda        String
  cliente_idCliente Int
  tipo              String
  formapagto        String
  desconto          Float
  total             Float
  created_at        String         @default("")
  cliente           Cliente        @relation(fields: [cliente_idCliente], references: [idCliente])
  produto_vendas    ProdutoVenda[]
}

model ProdutoVenda {
  idproduto_venda         Int     @id @default(autoincrement())
  quantidade              Int
  preco                   Float
  total                   Float
  venda_idvenda           Int
  venda_cliente_idCliente Int
  produto_idproduto       Int
  venda                   Venda   @relation(fields: [venda_idvenda], references: [idvenda])
  produto                 Produto @relation(fields: [produto_idproduto], references: [idproduto])
}



